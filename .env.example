# Solana Configuration
SOLANA_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_SYNAPSE_API_KEY
SOLANA_CLUSTER=mainnet-beta

# Agent Keypair
AGENT_KEYPAIR_PATH=./keys/dataflow-agent.json

# Ace Data Cloud Configuration
ACE_DATA_CLOUD_API_URL=https://api.acedata.cloud
# Note: x402 handles payments automatically, no API key needed
# Just sign up at platform.acedata.cloud for free credits

# Payment Configuration
PRICE_PER_CALL_LAMPORTS=1000000
MAX_CALLS_PER_ESCROW=100
DEFAULT_DEPOSIT_LAMPORTS=100000000

# Optional: For demo/testing
CLIENT_KEYPAIR_PATH=./keys/client-test.json
